{
  "extends": "@react-native/typescript-config",
  "compilerOptions": {
    "types": ["jest"],
    "baseUrl": "src",
    "paths": {
      "@screens/*": ["screens/*"],
      "@components/*": ["components/*"],
      "@features/*": ["features/*"],
      "@utils/*": ["utils/*"],
      "@hooks/*": ["hooks/*"],
      "@Productcomponents/*": ["features/products/components/*"],
      "@productScreens/*": ["features/products/screens/*"],
      "@products/*": ["features/products/*"],
      "@Productstypes/*": ["features/products/types/*"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx"],
  "exclude": ["**/node_modules", "**/Pods"]
}
